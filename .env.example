# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=
DEEPSEEK_API_KEY=
ALLOWED_USER_ID=          # message @userinfobot on Telegram to get yours

# ── Google Calendar ───────────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Desktop app type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
OAUTH_REDIRECT_PORT=8765        # redirect target for /login flow
MORNING_DIGEST_HOUR=6           # hour (0-23) to send the morning digest
EVENING_DIGEST_HOUR=20          # hour (0-23) to send the evening digest
TASKS_DB_PATH=tasks.json        # TinyDB storage file path
BACKLOG_DB_PATH=backlog.json    # TinyDB storage file for backlog ideas
AUTH_DB_PATH=auth.json          # TinyDB storage for persisted OAuth refresh token
TRACKING_STATE_PATH=tracking_state.json  # JSON file for live tracking session state
TRACKING_NUDGE_MINUTES=15      # how often (minutes) to ask "¿Qué estás haciendo?" when idle
TRACKING_ACTIVE_NUDGE_MINUTES=20  # how often (minutes) to ask "¿Sigues haciendo X?" in indefinido mode
USER_PROFILE_PATH=user_profile.json  # JSON file with personal context (gitignored)
