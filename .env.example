# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=
DEEPSEEK_API_KEY=
ALLOWED_USER_ID=          # message @userinfobot on Telegram to get yours

# ── Google Calendar ───────────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Desktop app type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Obtained at runtime via /login + /authcode inside Telegram.
# Leave empty on first deploy — the bot will prompt you to authenticate.
# After /authcode succeeds the bot prints the token; paste it here for restarts.
GOOGLE_REFRESH_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary      # "primary" = your main calendar
OAUTH_REDIRECT_PORT=8765        # redirect target for /login flow
REMINDER_INTERVAL_HOURS=6       # how often the task reminder fires
TASKS_DB_PATH=tasks.json        # TinyDB storage file path
