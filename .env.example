BOT_TOKEN=your-telegram-bot-token-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Optional: set this to a chat_id so the bot proactively messages that chat
# Get your chat_id by messaging @userinfobot on Telegram
PROACTIVE_CHAT_ID=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Service account JSON (raw or base64-encoded). Steps to get it:
#   1. Google Cloud Console → IAM → Service Accounts → Create
#   2. Create a JSON key, download it
#   3. Paste the raw JSON here (or base64-encode it: base64 -w0 key.json)
#   4. Share your Google Calendar with the service account email
GOOGLE_SERVICE_ACCOUNT_JSON=

# The calendar to operate on ("primary" = your main calendar)
GOOGLE_CALENDAR_ID=primary

# ── Tasks (TinyDB) ────────────────────────────────────────────────────────────
# Path to the local JSON file used as the task database (default: tasks.json)
TASKS_DB_PATH=tasks.json
