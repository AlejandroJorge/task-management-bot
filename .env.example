BOT_TOKEN=your-telegram-bot-token-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Your Telegram user ID — bot ignores everyone else.
# Get it by messaging @userinfobot on Telegram.
ALLOWED_USER_ID=

# How often to send the task reminder (default: every 6 hours)
REMINDER_INTERVAL_HOURS=6

# ── Google Calendar (OAuth2) ──────────────────────────────────────────────────
# Run scripts/get_refresh_token.py once to obtain these values.
# In Google Cloud Console: Credentials → Create OAuth 2.0 Client ID (Desktop app)
# Download client_secret.json, then: uv run scripts/get_refresh_token.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# The calendar to operate on ("primary" = your main calendar)
GOOGLE_CALENDAR_ID=primary

# ── Tasks (TinyDB) ────────────────────────────────────────────────────────────
# Path to the local JSON file used as the task database (default: tasks.json)
TASKS_DB_PATH=tasks.json
