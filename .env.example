# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=
ALLOWED_USER_ID=              # send /start to @userinfobot on Telegram to get yours

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
OAUTH_REDIRECT_PORT=8765            # local port for the /login OAuth callback
PUBLIC_URL=http://localhost:8765    # full redirect URI; override for non-localhost deployments

MORNING_DIGEST_HOUR=6               # hour (0-23) for the morning digest
EVENING_DIGEST_HOUR=20              # hour (0-23) for the evening digest

TASKS_DB_PATH=data/tasks.json           # TinyDB file for tasks
BACKLOG_DB_PATH=data/backlog.json       # TinyDB file for backlog ideas
AUTH_DB_PATH=data/auth.json             # TinyDB file for persisted OAuth refresh token
TRACKING_STATE_PATH=data/tracking_state.json  # JSON file for live tracking session state

TRACKING_NUDGE_MINUTES=15           # status message refresh interval (push notification)
